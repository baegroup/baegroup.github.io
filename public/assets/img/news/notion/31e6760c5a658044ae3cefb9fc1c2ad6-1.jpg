D_VIDEO"}]}},"removeFromWatchLaterCommand":{"clickTrackingParams":"CAAQu2kiEwj2naG4xpKTAxUSmlYBHVOQJ_XKAQROO4A3","commandMetadata":{"webCommandMetadata":{"sendPost":true,"apiUrl":"/youtubei/v1/browse/edit_playlist"}},"playlistEditEndpoint":{"playlistId":"WL","actions":[{"action":"ACTION_REMOVE_VIDEO_BY_VIDEO_ID","removedVideoId":"YL2XiSLteLA"}]}}}}},"storyboards":{"playerStoryboardSpecRenderer":{"spec":"https://i.ytimg.com/sb/YL2XiSLteLA/storyboard3_L$L/$N.jpg?sqp=-oaymwGhAUg48quKqQOYAYgBAZUBAAAEQpgBMqABPKgBBLIBQBANDBAVHyYtDg4PEhcrLCkPDhAVHyoyKQ8RFBgmPTgtERQeKjFLRzYVHCkuOUdNPyUuNz1HUlFFM0BCQ0xERkO6AUARERUjRENDQxETFi9DQ0NDFRYpQ0NDQ0MjL0NDQ0NDQ0RDQ0NDQ0JCQ0NDQ0NCQkJDQ0NDQkJCQkNDQ0JCQkJCovOX_wMGCIyT3u8F|48#27#100#10#10#0#default#rs$AOn4CLAPVzWmlQQVdb8ingXDxLqYt1xL1Q|80#45#120#10#10#1000#M$M#rs$AOn4CLDp089Gr4B-_1i6Y9OgEy9OGsEW_Q|160#90#120#5#5#1000#M$M#rs$AOn4CLBPk2r-vDU6Z40xQaQ2cmVPaM2lgw","recommendedLevel":2,"highResolutionRecommendedLevel":2}},"microformat":{"playerMicroformatRenderer":{"thumbnail":{"thumbnails":[{"url":"https://i.ytimg.com/vi/YL2XiSLteLA/maxresdefault.jpg","width":1280,"height":720}]},"embed":{"iframeUrl":"https://www.youtube.com/embed/YL2XiSLteLA","width":1280,"height":720},"title":{"simpleText":"'물 몇 방울로 전기를'…물을 이용한 자가발전기 개발 / 연합뉴스TV (YonhapnewsTV)"},"description":{"simpleText":"'물 몇 방울로 전기를'…물을 이용한 자가발전기 개발\n\n[앵커]\n\n국내 연구진이 물 몇 방울만 있으면 전기를 생산할 수 있는 발전기를 개발했습니다. \n\n이제 20%의 습도가 있는 곳이면 어디에서든 전기를 만들어낼 수 있는 자가 발전시대를 여는 기술적 토대를 확보했다는 평가입니다. \n\n이호진 기자입니다.\n\n[기자]\n \n면직물에 탄소소재를 코팅합니다.\n\n코팅된 면직물을 여러장 붙이고 전기선을 연결합니다.\n\n그리고 물을 떨어뜨리자 전기선 끝에 있던 LED전구가 빛나기 시작합니다.\n\n물을 이용해 전기를 생산하는 자가발전기 입니다.\n\n[윤태광 / KAIST 웨어러블플랫폼센터 연구원] \"단순하게 에너지를 저장하는 데서 그치지 않고 저희가 직접 생성도 할 수 있고 동시에 사용도 할 수 있는 시스템을 만들어 보면 어떨까 싶어서 저희 주변에서 쉽게 구할 수 있는 물질들을 이용해서 한번 제작해보자 그런 취지로…\"\n\n이렇게 모아진 전기로는 작은 선풍기도 돌릴 수 있습니다.\n\n젖어 있는 곳에서 마른 곳으로 수분이 이동하면서 전류가 생산되는 원리를 이용한 겁니다.\n\n면직물은 수분 흡수를, 탄소는 전기전달을 하는 역할입니다.\n\n이렇게 면과 탄소입자, 그리고 물만 있으면 쉽게 전기를 만들어 낼 수 있습니다.\n\n이번에 개발된 물을 이용한 자가 발전기에 흡습제 성분인 조해성 염을 붙이면 지속적으로 전기 생산이 가능합니다.\n\n20%의 습도만으로 지속적으로 스스로 전기를 생산합니다.\n\n특히 면직물과 탄소 등은 쉽게 구할 수 있는 소재여서 활용도는 무궁무진합니다.\n \n[김일두 / KAIST 신소재공학과 교수] \"이러한 자가 발전기들을 직렬 또는 병렬로 연결하면 전력량을 손쉽게 높일 수 있기 때문에 웨어러블기기의 에너지원이나 IOT(사물인터넷)용 센서기기의 전력원으로 활용할 수 있습니다.\"\n\n연구진은 물을 이용한 자가발전기의 전류량을 늘리는 기술을 추가로 연구하고 있다고 밝혔습니다.\n\n연합뉴스TV 이호진입니다.\n    \n연합뉴스TV 기사문의 및 제보 : 카톡/라인 jebo23\n\n▣ 연합뉴스TV 유튜브 채널 구독\r\nhttps://goo.gl/VuCJMi\r\n▣ 대한민국 뉴스의 시작 연합뉴스TV / Yonhap News TV\r\nhttp://www.yonhapnewstv.co.kr/"},"lengthSeconds":"119","ownerProfileUrl":"http://www.youtube.com/@yonhapnewstv23","externalChannelId":"UCTHCOPwqNfZ0uiKOvFyhGwg","isFamilySafe":true,"availableCountries":["AD","AE","AF","AG","AI","AL","AM","AO","AQ","AR","AS","AT","AU","AW","AX","AZ","BA","BB","BD","BE","BF","BG","BH","BI","BJ","BL","BM","BN","BO","BQ","BR","BS","BT","BV","BW","BY","BZ","CA","CC","CD","CF","CG","CH","CI","CK","CL","CM","CN","CO","CR","CU","CV","CW","CX","CY","CZ","DE","DJ","DK","DM","DO","DZ","EC","EE","EG","EH","ER","ES","ET","FI","FJ","FK","FM","FO","FR","GA","GB","GD","GE","GF","GG","GH","GI","GL","GM","GN","GP","GQ","GR","GS","GT","GU","GW","GY","HK","HM","HN","HR","HT","HU","ID","IE","IL","IM","IN","IO","IQ","IR","IS","IT","JE","JM","JO","JP","KE","KG","KH","KI","KM","KN","KP","KR","KW","KY","KZ","LA","LB","LC","LI","LK","LR","LS","LT","LU","LV","LY","MA","MC","MD","ME","MF","MG","MH","MK","ML","MM","MN","MO","MP","MQ","MR","MS","MT","MU","MV","MW","MX","MY","MZ","NA","NC","NE","NF","NG","NI","NL","NO","NP","NR","NU","NZ","OM","PA","PE","PF","PG","PH","PK","PL","PM","PN","PR","PS","PT","PW","PY","QA","RE","RO","RS","RU","RW","SA","SB","SC","SD","SE","SG","SH","SI","SJ","SK","SL","SM","SN","SO","SR","SS","ST","SV","SX","SY","SZ","TC","TD","TF","TG","TH","TJ","TK","TL","TM","TN","TO","TR","TT","TV","TW","TZ","UA","UG","UM","US","UY","UZ","VA","VC","VE","VG","VI","VN","VU","WF","WS","YE","YT","ZA","ZM","ZW"],"isUnlisted":false,"hasYpcMetadata":false,"viewCount":"32577","category":"News \u0026 Politics","publishD