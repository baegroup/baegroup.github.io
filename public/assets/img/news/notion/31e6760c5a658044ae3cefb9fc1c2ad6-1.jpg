clickTrackingParams":"CIUCEJsrIhMIt52huMaSkwMV75FGBB1pOCrLygEETjuANw==","commandMetadata":{"webCommandMetadata":{"sendPost":true}},"signalServiceEndpoint":{"signal":"CLIENT_SIGNAL","actions":[{"clickTrackingParams":"CIUCEJsrIhMIt52huMaSkwMV75FGBB1pOCrLygEETjuANw==","openPopupAction":{"popup":{"confirmDialogRenderer":{"trackingParams":"CIYCEMY4IhMIt52huMaSkwMV75FGBB1pOCrL","dialogMessages":[{"runs":[{"text":"연합뉴스TV"},{"text":" 구독을 취소하시겠습니까?"}]}],"confirmButton":{"buttonRenderer":{"style":"STYLE_BLUE_TEXT","size":"SIZE_DEFAULT","isDisabled":false,"text":{"runs":[{"text":"구독 취소"}]},"serviceEndpoint":{"clickTrackingParams":"CIgCEPBbIhMIt52huMaSkwMV75FGBB1pOCrLKPgdMgV3YXRjaMoBBE47gDc=","commandMetadata":{"webCommandMetadata":{"sendPost":true,"apiUrl":"/youtubei/v1/subscription/unsubscribe"}},"unsubscribeEndpoint":{"channelIds":["UCTHCOPwqNfZ0uiKOvFyhGwg"],"params":"CgIIAxILWUwyWGlTTHRlTEEYAA%3D%3D"}},"accessibility":{"label":"구독 취소"},"trackingParams":"CIgCEPBbIhMIt52huMaSkwMV75FGBB1pOCrL"}},"cancelButton":{"buttonRenderer":{"style":"STYLE_TEXT","size":"SIZE_DEFAULT","isDisabled":false,"text":{"runs":[{"text":"취소"}]},"accessibility":{"label":"취소"},"trackingParams":"CIcCEPBbIhMIt52huMaSkwMV75FGBB1pOCrL"}},"primaryIsCancel":false}},"popupType":"DIALOG"}}]}}]}},"metadataRowContainer":{"metadataRowContainerRenderer":{"collapsedItemCount":0,"trackingParams":"CIQCEM2rARgBIhMIt52huMaSkwMV75FGBB1pOCrL"}},"showMoreText":{"simpleText":"...더보기"},"showLessText":{"simpleText":"간략히"},"trackingParams":"CIQCEM2rARgBIhMIt52huMaSkwMV75FGBB1pOCrL","defaultExpanded":false,"descriptionCollapsedLines":3,"showMoreCommand":{"clickTrackingParams":"CIQCEM2rARgBIhMIt52huMaSkwMV75FGBB1pOCrLygEETjuANw==","commandExecutorCommand":{"commands":[{"clickTrackingParams":"CIQCEM2rARgBIhMIt52huMaSkwMV75FGBB1pOCrLygEETjuANw==","changeEngagementPanelVisibilityAction":{"targetId":"engagement-panel-structured-description","visibility":"ENGAGEMENT_PANEL_VISIBILITY_EXPANDED"}},{"clickTrackingParams":"CIQCEM2rARgBIhMIt52huMaSkwMV75FGBB1pOCrLygEETjuANw==","scrollToEngagementPanelCommand":{"targetId":"engagement-panel-structured-description"}}]}},"showLessCommand":{"clickTrackingParams":"CIQCEM2rARgBIhMIt52huMaSkwMV75FGBB1pOCrLygEETjuANw==","changeEngagementPanelVisibilityAction":{"targetId":"engagement-panel-structured-description","visibility":"ENGAGEMENT_PANEL_VISIBILITY_HIDDEN"}},"attributedDescription":{"content":"'물 몇 방울로 전기를'…물을 이용한 자가발전기 개발\n\n[앵커]\n\n국내 연구진이 물 몇 방울만 있으면 전기를 생산할 수 있는 발전기를 개발했습니다. \n\n이제 20%의 습도가 있는 곳이면 어디에서든 전기를 만들어낼 수 있는 자가 발전시대를 여는 기술적 토대를 확보했다는 평가입니다. \n\n이호진 기자입니다.\n\n[기자]\n \n면직물에 탄소소재를 코팅합니다.\n\n코팅된 면직물을 여러장 붙이고 전기선을 연결합니다.\n\n그리고 물을 떨어뜨리자 전기선 끝에 있던 LED전구가 빛나기 시작합니다.\n\n물을 이용해 전기를 생산하는 자가발전기 입니다.\n\n[윤태광 / KAIST 웨어러블플랫폼센터 연구원] \"단순하게 에너지를 저장하는 데서 그치지 않고 저희가 직접 생성도 할 수 있고 동시에 사용도 할 수 있는 시스템을 만들어 보면 어떨까 싶어서 저희 주변에서 쉽게 구할 수 있는 물질들을 이용해서 한번 제작해보자 그런 취지로…\"\n\n이렇게 모아진 전기로는 작은 선풍기도 돌릴 수 있습니다.\n\n젖어 있는 곳에서 마른 곳으로 수분이 이동하면서 전류가 생산되는 원리를 이용한 겁니다.\n\n면직물은 수분 흡수를, 탄소는 전기전달을 하는 역할입니다.\n\n이렇게 면과 탄소입자, 그리고 물만 있으면 쉽게 전기를 만들어 낼 수 있습니다.\n\n이번에 개발된 물을 이용한 자가 발전기에 흡습제 성분인 조해성 염을 붙이면 지속적으로 전기 생산이 가능합니다.\n\n20%의 습도만으로 지속적으로 스스로 전기를 생산합니다.\n\n특히 면직물과 탄소 등은 쉽게 구할 수 있는 소재여서 활용도는 무궁무진합니다.\n \n[김일두 / KAIST 신소재공학과 교수] \"이러한 자가 발전기들을 직렬 또는 병렬로 연결하면 전력량을 손쉽게 높일 수 있기 때문에 웨어러블기기의 에너지원이나 IOT(사물인터넷)용 센서기기의 전력원으로 활용할 수 있습니다.\"\n\n연구진은 물을 이용한 자가발전기의 전류량을 늘리는 기술을 추가로 연구하고 있다고 밝혔습니다.\n\n연합뉴스TV 이호진입니다.\n    \n연합뉴스TV 기사문의 및 제보 : 카톡/라인 jebo23\n\n▣ 연합뉴스TV 유튜브 채널 구독\r\nhttps://goo.gl/VuCJMi\r\n▣ 대한민국 뉴스의 시작 연합뉴스TV / Yonhap News TV\r\nhttp://www.yonhapnewstv.co.kr/","commandRuns":[{"startIndex":1010,"length":21,"onTap":{"innertubeCommand":{"clickTrackingParams":"CIQCEM2rARgBIhMIt52huMaSkwMV75FGBB1pOCrLSLDxtZeS8eXeYMoBBE47gDc=","commandMetadata":{"webCommandMetadata":{"url":"https://www.youtube.com/redirect?event=video_description\u0026redir_token=QUFFLUhqbHluNHptOWYxMFNwVy1rX2g4b3dHdUluUUQzZ3xBQ3Jtc0ttMHBCTWI3VkNXWTJkLUlKSzAxY1lwanc5SWtCdTVnaWxSOTZ5aG9BbHVJQUY3ZE16bTl2d2JsLXZEX2FMU3FFcWtVe